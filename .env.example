# Base site URL used to generate absolute metadata URLs.
# Set this per environment, for example:
# local: http://localhost:3000
# preview: https://your-preview-url.vercel.app
# production: https://filipemendes.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Enable placeholder docs used to test sidebar and docs index scalability.
# Set to "true" locally or in preview environments when you want demo content included.
ENABLE_DOCS_DEMOS=false
